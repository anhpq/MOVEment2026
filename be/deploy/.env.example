# Place at /opt/movement/app/be/.env on the ECS instance.
NODE_ENV=production
PORT=8080
DATABASE_URL=postgresql://user:password@host:5432/movement
JWT_SECRET=change-me
JWT_EXPIRES_IN=12h
SCORING_CODE=change-me
CORS_ORIGIN=https://heroes.nalth.top
FRONTEND_PUBLIC_URL=https://heroes.nalth.top
# Legacy fallback supported for existing deployments:
# PUBLIC_FRONTEND_URL=https://heroes.nalth.top
QR_LOGIN_TOKEN_TTL_MINUTES=1440
