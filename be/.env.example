# These values are for local development only. Production must set unique values
# for DATABASE_URL, JWT_SECRET, SCORING_CODE, and CORS_ORIGIN.
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/movement
# Remote PostgreSQL with a server/root CA PEM file:
# DATABASE_URL="postgresql://root:YOUR_URL_ENCODED_PASSWORD@DB_HOST:5432/movement?schema=public&sslmode=require&sslcert=certs/postgres-ca.pem&sslaccept=strict"
JWT_SECRET=change-me
JWT_EXPIRES_IN=12h
CORS_ORIGIN=http://localhost:5173
SCORING_CODE=2468
FRONTEND_PUBLIC_URL=http://localhost:4173
# Legacy fallback supported for existing deployments:
# PUBLIC_FRONTEND_URL=http://localhost:4173
QR_LOGIN_TOKEN_TTL_MINUTES=1440
